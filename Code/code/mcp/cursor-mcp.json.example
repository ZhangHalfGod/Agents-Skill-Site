{
  "mcpServers": {
    "agents-skill-local-file": {
      "command": "node",
      "args": [
        "REPLACE_WITH_ABSOLUTE_PATH/Agents-Skill-Site/Code/code/mcp/server.mjs"
      ],
      "env": {
        "MANIFEST_PATH": "REPLACE_WITH_ABSOLUTE_PATH/Agents-Skill-Site/Code/code/docs/public/manifest.json"
      }
    },
    "agents-skill": {
      "command": "node",
      "args": [
        "REPLACE_WITH_ABSOLUTE_PATH/Agents-Skill-Site/Code/code/mcp/server.mjs"
      ],
      "env": {
        "MANIFEST_URL": "http://YOUR_DEPLOYED_HOST/agents-skill/manifest.json"
      }
    }
  }
}
