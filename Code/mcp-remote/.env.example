# 复制为 .env（勿提交）。R1 本地示例：
MCP_TOKEN=change*************oken
HOST=127.0.0.1
PORT=3921

# 数据源：优先远程已发布索引；本地开发可改用 MANIFEST_PATH
MANIFEST_URL=http://YOUR_DEPLOYED_HOST/agents-skill/manifest.json
# MANIFEST_PATH=../code/docs/public/manifest.json
# CACHE_TTL_MS=60000

# 可选：Nginx 未把 Host 改成 127.0.0.1 时再设，例如：
# ALLOWED_HOSTS=YOUR_DEPLOYED_HOST,127.0.0.1
