# 复制到 Code/mcp-remote/.env（服务器本地，勿 git add）
# cp deploy/env.production.example /var/www/agents-skill-site/Code/mcp-remote/.env

MCP_TOKEN=replace-with-long-random-secret
HOST=127.0.0.1
PORT=3921

# 优先用构建树里的索引（不依赖 dist 软链是否存在）
MANIFEST_PATH=/var/www/agents-skill-site/Code/code/docs/public/manifest.json
# 若已按 07-deploy 建好 dist 软链，也可改用：
# MANIFEST_PATH=/var/www/agents-skill-site/dist/manifest.json

# 不要同时设 MANIFEST_URL（URL 优先会覆盖 PATH）
# MANIFEST_URL=

CACHE_TTL_MS=60000
